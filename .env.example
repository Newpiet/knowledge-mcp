# ── LLM Providers ──────────────────────────────────────────────
## OpenAI
OPENAI_API_KEY=<my key>
OPENAI_API_BASE=https://api.openai.com/v1/

## Azure OpenAI
AZURE_OPENAI_ENDPOINT=<my endpoint>
AZURE_OPENAI_API_KEY=<my key>
AZURE_OPENAI_API_VERSION=2023-05-15
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_EMBEDDING_API_VERSION=2023-05-15

# ── Web Server ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<change-me>

# Comma-separated list of allowed origins, e.g. https://app.example.com
# Leave as * only for local development
ALLOWED_ORIGINS=*

# Port to expose the web server on the host
WEB_PORT=8000

# Max concurrent LightRAG ingestion tasks (each uses significant CPU/RAM)
MAX_CONCURRENT_INGESTIONS=3

# Docker memory limit for the web container (e.g. 4g, 8g)
MEM_LIMIT=4g
